/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MTB end-to-end test profile (reuses XBS submodule's bundled resources)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Single-backend (gatk_vqsr → XBS) run on the 3 EXIT-RIF / PRJNA1026351
    samples XBS itself uses for its own end-to-end test. All paths point
    into the pinned XBS submodule — no duplicate resource bundling.

    Use:
        nextflow run mycobactopia-org/mtbc-varcaller-nf \
            -profile test,<docker|singularity|conda> \
            --outdir results/
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   4,
        memory: '15.GB',
        time:   '2.h',
    ]
}

params {
    config_profile_name        = 'MTB test profile'
    config_profile_description = '3 EXIT-RIF MTB samples via gatk_vqsr backend (XBS submodule)'

    // ── Input samplesheet (reuse XBS's bundled one) ──────────────────────────
    input               = "${projectDir}/submodules/xbs-variant-calling/assets/samplesheet_test.csv"

    // ── Reference: H37Rv bundled in the XBS submodule ────────────────────────
    reference_dir       = "${projectDir}/submodules/xbs-variant-calling/resources/genome"
    reference_basename  = 'NC-000962-3-H37Rv'

    // ── Backend + consensus (Phase-1 default: XBS only, best_single passthrough) ──
    backends            = 'gatk_vqsr'
    consensus           = 'best_single'
    consensus_backend   = 'gatk_vqsr'

    // ── XBS-side params: forward MAGMA-parity behaviour for MTB ──────────────
    snp_filter_mode     = 'vqsr'
    snp_truth_vcf       = "${projectDir}/submodules/xbs-variant-calling/resources/truth/Coll2018.UVPapproved.rRNAexcluded.vcf.gz"
    snp_truth_vcf_tbi   = "${params.snp_truth_vcf}.tbi"
    indel_filter_mode   = 'hard_filters'

    // VQSR small-N: 3 samples is below Heupink 2021's recommended 12+
    vqsr_max_gaussians_snp = 1

    // BQSR off (paper-true; matches MAGMA test profile)
    skip_bqsr           = true

    // MTB Ti/Tv (Heupink 2021)
    target_titv         = 1.85

    joint_name          = 'test_cohort'
    platform            = 'illumina'
}
