/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module ext.args / ext.prefix for mtbc-varcaller-nf
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    The submodule modules (XBS's BWA-MEM, GATK-VQSR chain, etc.) get their
    ext.args from the XBS submodule's own modules.config — we don't override
    those here unless we need to.

    What we DO configure here are the modules unique to mtbc-varcaller-nf:
    bcftools/concat (per-sample SNP+INDEL merge) and bcftools/norm
    (canonical-representation normalisation per spec §C).
----------------------------------------------------------------------------------------
*/

// Pick up the XBS submodule's modules.config so XBS-internal modules
// (BWA_MEM, GATK4_HAPLOTYPECALLER, etc.) keep their Heupink-2021 ext.args
// without us having to duplicate them.
includeConfig '../submodules/xbs-variant-calling/conf/modules.config'

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ============================================================
    // bcftools/concat — per-sample SNP + INDEL join inside the
    //                   gatk_vqsr backend (XBS emits them separately)
    // ============================================================
    withName: 'BCFTOOLS_CONCAT' {
        // -a allow records from different files to overlap
        // -O z bgzip output
        ext.args   = '-a -O z'
        ext.prefix = { "${meta.id}.${meta.backend ?: 'unknown'}.merged" }
    }

    // ============================================================
    // bcftools/norm — canonical-representation normalisation per
    //                 spec §C (left-align + split multiallelics + dedup).
    //                 Applied to every backend's per-sample VCF.
    // ============================================================
    withName: 'BCFTOOLS_NORM' {
        // -m -any   split multiallelics into separate biallelic records
        // -d none   no dedup (Phase-1 default; can be flipped to 'all' via override)
        // --check-ref w   warn on REF mismatch rather than fail
        // -O z      bgzip output
        // --write-index=tbi   emit .tbi alongside
        ext.args   = '-m -any -d none --check-ref w -O z --write-index=tbi'
        ext.prefix = { "${meta.id}.${meta.backend ?: 'unknown'}.norm" }
    }
}
